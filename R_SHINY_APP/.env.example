# ==============================================================================
# LIVESTOCK INTELLIGENCE - ENVIRONMENT VARIABLES
# Copy this file to .env and fill in with your actual database credentials
# ==============================================================================

# PostgreSQL Database Connection (Data Warehouse)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=datawarehouse_db
DB_USER=postgres
DB_PASSWORD=your_password_here

# Shapefile Path (relative to working directory)
SHAPEFILE_PATH=data/ADMINISTRAS_PROVINSI.shp

# Shiny App Configuration
SHINY_PORT=3838
SHINY_HOST=0.0.0.0

# Optional: For production deployment
# SHINY_DISPLAY_ERROR_DETAILS=FALSE
